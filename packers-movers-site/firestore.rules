rules_version = '2';

// ============================================================
// K&N PACKERS AND MOVERS — FIRESTORE SECURITY RULES
// ============================================================
// Principle: least privilege
// - Anyone can SUBMIT forms (quotes, contacts, complaints)
// - Only ADMIN users can VIEW/MANAGE submissions
// - Users can view their OWN complaints
// - Users can manage their OWN profile
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if current user is admin
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ============================================================
    // QUOTES — anyone can submit, only admin can view/manage
    // ============================================================
    match /quotes/{quoteId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ============================================================
    // CONTACTS — anyone can submit, only admin can view/manage
    // ============================================================
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ============================================================
    // COMPLAINTS — anyone can submit; users see own; admin sees all
    // ============================================================
    match /complaints/{complaintId} {
      allow create: if true;

      // Read: owner OR admin
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());

      // Update/Delete: admin only
      allow update, delete: if isAdmin();
    }

    // ============================================================
    // USERS — users manage their own profile; admin sees all
    // ============================================================
    match /users/{userId} {
      // Anyone logged in can read user profiles (for ownership checks)
      allow read: if request.auth != null;

      // Users can create their own profile
      allow create: if request.auth != null && request.auth.uid == userId;

      // Users can update their own profile
      allow update: if request.auth != null
        && (request.auth.uid == userId || isAdmin());

      // Only admin can delete users
      allow delete: if isAdmin();
    }

    // ============================================================
    // BLOCK everything else by default
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
